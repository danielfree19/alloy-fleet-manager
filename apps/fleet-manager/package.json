{
  "name": "@fleet/fleet-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "migrate": "node-pg-migrate --envPath ../../.env -m src/db/migrations -j sql up",
    "migrate:down": "node-pg-migrate --envPath ../../.env -m src/db/migrations -j sql down",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@fleet/shared": "*",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "js-yaml": "^4.1.1",
    "node-pg-migrate": "^7.3.1",
    "openid-client": "^5.7.1",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.1.0",
    "protobufjs": "^7.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.11.6",
    "vitest": "^4.1.5"
  }
}
