# ==============================================================
# Alloy Fleet Manager - example environment
# Copy to .env for local dev (used by docker-compose and apps).
# ==============================================================

# ---- Postgres ----
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet
POSTGRES_DB=fleet
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
# DATABASE_URL is used when you run the manager on the HOST (npm run dev:manager,
# npm run migrate, etc.) — it must match the host-side port mapping above.
# When the manager runs INSIDE docker-compose, docker-compose.yml overrides
# this to postgres://fleet:fleet@postgres:5432/fleet (the container network).
DATABASE_URL=postgres://fleet:fleet@localhost:5433/fleet

# ---- Fleet Manager API ----
FLEET_MANAGER_HOST=0.0.0.0
FLEET_MANAGER_PORT=9090
# Bearer token for admin endpoints (pipelines CRUD, legacy /collectors, etc.).
ADMIN_TOKEN=change-me-admin-token
# Bearer token the LEGACY fleet-agent sends on POST /legacy/collectors/register.
REGISTRATION_TOKEN=change-me-registration-token
# Bearer token Alloy instances send in the remotecfg `bearer_token` field.
# Shared across all collectors for MVP (per-collector tokens are future work).
AGENT_BEARER_TOKEN=change-me-agent-bearer-token
LOG_LEVEL=info

# ---- Fleet Agent ----
FLEET_MANAGER_URL=http://localhost:9090
# Used only on first boot to call /collectors/register.
REGISTRATION_TOKEN_AGENT=change-me-registration-token
AGENT_HOSTNAME=
AGENT_ENVIRONMENT=dev
# JSON object of labels, e.g. {"role":"edge","region":"eu-west"}
AGENT_LABELS={}
ALLOY_CONFIG_PATH=/etc/alloy/config.alloy
ALLOY_RELOAD_URL=http://localhost:12345/-/reload
AGENT_STATE_PATH=./state/agent-state.json
POLL_INTERVAL_SECONDS=30
