{
  "name": "@fleet-oss/sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the self-hosted Alloy Fleet Manager admin API.",
  "license": "Apache-2.0",
  "author": "The Fleet OSS Authors",
  "homepage": "https://gitlab.thepcport.com/fleet-oss/alloy-fleet-manager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.thepcport.com/fleet-oss/alloy-fleet-manager.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://gitlab.thepcport.com/fleet-oss/alloy-fleet-manager/-/issues"
  },
  "keywords": [
    "grafana",
    "alloy",
    "fleet-management",
    "remotecfg",
    "observability",
    "telemetry"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "node -e \"require('fs').copyFileSync('../../LICENSE','LICENSE');require('fs').copyFileSync('../../NOTICE','NOTICE')\""
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
